{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QueryMsg",
  "oneOf": [
    {
      "description": "CW20 Balance. Returns underlying (scaled × liquidity_index) when pool_address is set.",
      "type": "object",
      "required": [
        "balance"
      ],
      "properties": {
        "balance": {
          "type": "object",
          "required": [
            "address"
          ],
          "properties": {
            "address": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Scaled balance (raw stored amount). Used by pool for admin Withdraw on behalf of lender.",
      "type": "object",
      "required": [
        "scaled_balance"
      ],
      "properties": {
        "scaled_balance": {
          "type": "object",
          "required": [
            "address"
          ],
          "properties": {
            "address": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "CW20 TokenInfo. total_supply is underlying when pool_address is set.",
      "type": "object",
      "required": [
        "token_info"
      ],
      "properties": {
        "token_info": {
          "type": "object",
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "CW20 Minter.",
      "type": "object",
      "required": [
        "minter"
      ],
      "properties": {
        "minter": {
          "type": "object",
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "All holders with balance greater than 0",
      "type": "object",
      "required": [
        "all_accounts"
      ],
      "properties": {
        "all_accounts": {
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max addresses per page (CW20 `u32` limit field).",
              "type": [
                "integer",
                "null"
              ],
              "format": "uint32",
              "minimum": 0.0
            },
            "start_after": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Query the contract's ownership information",
      "type": "object",
      "required": [
        "ownership"
      ],
      "properties": {
        "ownership": {
          "type": "object",
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}
