            "prev_asset": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "get_prices_by_asset"
      ],
      "properties": {
        "get_prices_by_asset": {
          "type": "object",
